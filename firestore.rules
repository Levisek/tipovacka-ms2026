rules_version = '2';

// Appka nemá přihlašování (identita = jméno hráče v localStorage), takže
// nejde "jen vlastník edituje". Co řešíme: ZÁKAZ mazání (nikdo newipne data)
// a validace TVARU zápisu (žádný garbage). Bez `let` — kompatibilní i s v1.

service cloud.firestore {
  match /databases/{database}/documents {

    // Tipy na zápasy: matches/{matchId}/bets/{player}
    match /matches/{matchId}/bets/{player} {
      allow read: if true;
      allow create, update: if request.resource.data.homeScore is int
        && request.resource.data.awayScore is int
        && request.resource.data.homeScore >= 0 && request.resource.data.homeScore <= 20
        && request.resource.data.awayScore >= 0 && request.resource.data.awayScore <= 20;
      allow delete: if false;
    }

    // Samotný dokument zápasu se z klienta needituje.
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    // Výsledky: plní cron i ruční zadání v adminu. Klient jinak jen čte.
    match /results/{matchId} {
      allow read: if true;
      allow create, update: if request.resource.data.homeScore is int
        && request.resource.data.awayScore is int
        && request.resource.data.homeScore >= 0 && request.resource.data.homeScore <= 50
        && request.resource.data.awayScore >= 0 && request.resource.data.awayScore <= 50;
      allow delete: if false;
    }

    // Tip na vítěze: winnerBets/{player}
    match /winnerBets/{player} {
      allow read: if true;
      allow create, update: if request.resource.data.team is string
        && request.resource.data.team.size() > 0
        && request.resource.data.team.size() < 40;
      allow delete: if false;
    }

    // Evidence plateb: payments/{player} = { groups: bool, knockout: bool }
    match /payments/{player} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // Odběry push notifikací: pushSubs/{hashEndpointu} = { endpoint, ... }
    // Klient zakládá, cron čte (rozesílá) a maže mrtvé odběry (404/410).
    match /pushSubs/{id} {
      allow read: if true;
      allow create, update: if request.resource.data.endpoint is string;
      allow delete: if true;
    }

    // Záznam, že připomínka na daný hrací den už byla odeslána (proti duplicitám).
    // Píše jen cron; klient se sem nedostane.
    match /notifyLog/{day} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // Cokoli jiného: zakázat.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
